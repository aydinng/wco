generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Neon: migrate kullanır; pooler yerine doğrudan endpoint (P1001 / migration uyumu)
  directUrl = env("DIRECT_URL")
}

/// Tek satır: tüm oyuncuların gördüğü dünya çağı (arka plan)
model GameSettings {
  id         String @id @default("singleton")
  currentEra String @default("ilk_cag")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  passwordHash String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  /// Kayıt e-postası (benzersiz)
  email     String?  @unique

  /// KVKK / aydınlatma metni onayı zamanı
  kvkkAcceptedAt DateTime?

  /// Kayıt sırasında seçilen ülke (giriş sayfası listesi için)
  registrationCountry String @default("")

  title       String @default("General")
  role        String @default("Player")
  nationName  String @default("United States of America")
  tribeName   String @default("Americans")

  /// İmparatorluk genelinde araştırma seviyesi (üretim çarpanı)
  researchTier Int @default(0)

  /// Devam eden araştırma işi bitiş zamanı; null = kuyruk boş
  researchJobEndsAt DateTime?

  /// Oyuncunun bulunduğu çağ (kaynak kilidi + arka plan); yeni üye ilk çağdan başlar
  currentEra String @default("ilk_cag")

  /// Skor bileşenleri (istatistik / sıralama)
  scoreTotal       Int @default(0)
  scoreProduction  Int @default(0)
  scoreTech        Int @default(0)
  scoreBuilding    Int @default(0)

  /// Son istek (oyunda çevrim içi sayımı için; /api/presence/ping)
  lastSeenAt DateTime?

  @@index([lastSeenAt])

  blockIncomingMessages Boolean @default(false)
  settingSoundEnabled   Boolean @default(true)
  settingNotifyBattle   Boolean @default(true)
  settingCompactTables  Boolean @default(false)

  cities       City[]
  fleets       Fleet[]
  battleReports BattleReport[] @relation("AttackerReports")
  marketSales   MarketListing[] @relation("MarketSeller")
  marketBuys    MarketListing[] @relation("MarketBuyer")

  trainingJobs TrainingJob[]
  buildingJobs BuildingJob[]

  sentMessages     DirectMessage[] @relation("SentMessages")
  receivedMessages DirectMessage[] @relation("ReceivedMessages")
  adminTickets     AdminTicket[]
  foundedAlliances Alliance[]      @relation("AllianceFounder")
  allianceMember   AllianceMember?

  userEraTechs      UserEraTech[]
  eraTechJobs       EraTechResearchJob[]
  allianceMessages  AllianceMessage[]
  allianceInvitesSent     AllianceInvite[] @relation("AllianceInviteFrom")
  allianceInvitesReceived AllianceInvite[] @relation("AllianceInviteTo")

  forumTopics ForumTopic[]
  forumPosts  ForumPost[]
}

model CityUnitStock {
  id       String @id @default(cuid())
  cityId   String
  city     City   @relation(fields: [cityId], references: [id], onDelete: Cascade)
  unitId   String
  quantity Int    @default(0)

  @@unique([cityId, unitId])
  @@index([cityId])
}

model Alliance {
  id         String   @id @default(cuid())
  name       String   @unique
  founderId  String
  founder    User     @relation("AllianceFounder", fields: [founderId], references: [id], onDelete: Cascade)
  inviteOnly Boolean  @default(false)
  /// Üye üst sınırı (ileride bonuslarla artırılabilir)
  maxMembers Int      @default(50)
  createdAt  DateTime @default(now())

  members  AllianceMember[]
  messages AllianceMessage[]
  invites  AllianceInvite[]
}

model AllianceMessage {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String   @db.VarChar(2000)
  createdAt  DateTime @default(now())

  @@index([allianceId, createdAt])
}

/// Lider davet gönderir; hedef kullanıcı kabul edene kadar bekler
model AllianceInvite {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  fromUserId String
  fromUser   User     @relation("AllianceInviteFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User     @relation("AllianceInviteTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([toUserId, status])
  @@index([allianceId])
}

model AllianceMember {
  id         String   @id @default(cuid())
  allianceId String
  alliance   Alliance @relation(fields: [allianceId], references: [id], onDelete: Cascade)
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("member")
  joinedAt   DateTime @default(now())

  @@index([allianceId])
}

model AdminTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  body      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model DirectMessage {
  id         String    @id @default(cuid())
  fromUserId String
  fromUser   User      @relation("SentMessages", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String
  toUser     User      @relation("ReceivedMessages", fields: [toUserId], references: [id], onDelete: Cascade)
  subject    String
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  @@index([toUserId, createdAt])
  @@index([fromUserId])
}

model Fleet {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  fromCityId String
  fromCity   City   @relation(fields: [fromCityId], references: [id], onDelete: Cascade)

  toCoordX Int
  toCoordY Int
  toCoordZ Int

  departAt DateTime
  arriveAt DateTime

  status String @default("traveling")

  attackPower  Int @default(0)
  defensePower Int @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  report BattleReport?

  @@index([userId])
  @@index([fromCityId])
  @@index([arriveAt])
}

model BattleReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  fleetId String @unique
  fleet   Fleet  @relation(fields: [fleetId], references: [id], onDelete: Cascade)

  attackerUserId String
  attacker       User   @relation("AttackerReports", fields: [attackerUserId], references: [id], onDelete: Cascade)

  defenderCoord String

  attackerTotal Int
  defenderTotal Int
  outcome       String
  summary       String

  @@index([attackerUserId])
}

model City {
  id         String   @id @default(cuid())
  name       String
  createdAt  DateTime @default(now())

  coordX     Int      @default(0)
  coordY     Int      @default(0)
  coordZ     Int      @default(0)

  wood       Int      @default(0)
  iron       Int      @default(0)
  oil        Int      @default(0)
  food       Int      @default(0)

  population Int      @default(0)
  popCap     Int      @default(250)

  workersWood Int     @default(0)
  workersIron Int     @default(0)
  workersOil  Int     @default(0)
  workersFood Int     @default(0)

  /// 0 = inşa edilmedi; 1+ = seviye (WarCity tarzı)
  townHallLevel   Int @default(0)
  lumberMillLevel Int @default(0)
  ironMineLevel   Int @default(0)
  oilWellLevel    Int @default(0)
  farmLevel       Int @default(0)
  barracksLevel   Int @default(0)
  researchLodgeLevel Int @default(0)
  shepherdLodgeLevel Int @default(0)
  civilLodgeLevel    Int @default(0)
  bankLevel          Int @default(0)
  policeDeptLevel    Int @default(0)
  /// Kışlada eğitilmiş asker (filo saldırı önerisi için)
  soldiers        Int @default(0)

  /// Son kaynak tick (saatlik üretim / besin tüketimi)
  lastResourceTick DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  fleets     Fleet[]
  marketListings MarketListing[] @relation("ListingCity")
  marketIncoming MarketListing[] @relation("BuyerCity")
  trainingJobs TrainingJob[]
  buildingJobs BuildingJob[]
  cityUnitStocks CityUnitStock[]
  eraTechJobs  EraTechResearchJob[]

  @@index([userId])
}

/// Çağ teknolojisi: çoğu teknoloji en fazla 1. seviye
model UserEraTech {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  techKey String
  level   Int    @default(0)

  @@unique([userId, techKey])
  @@index([userId])
}

model EraTechResearchJob {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityId      String
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  techKey     String
  durationSec Int
  /// null = sırada bekliyor; ilk iş bitince dolar (aynı anda tek aktif süre)
  completesAt DateTime?
  status      String   @default("queued")

  @@index([userId, status])
  @@index([completesAt])
}

/// Bina yükseltme kuyruğu: en fazla 2 kayıt; aynı anda yalnızca birinin süresi işler (sırayla)
model BuildingJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  buildingId String
  fromLevel Int
  toLevel Int
  durationSec Int

  startsAt DateTime
  /// null = sırada bekliyor; önceki iş bitince başlar
  completesAt DateTime?

  status String @default("queued") // queued | done | cancelled

  @@index([userId])
  @@index([cityId])
  @@index([status, completesAt])
}

/// Üretim kuyruğu: her kayıt 1 adet askeri temsil eder (sıralı üretim için)
model TrainingJob {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  unitId String
  /// Bu kuyruk kaydında eğitilecek toplam asker (1–50)
  quantity    Int @default(1)
  durationSec Int

  startsAt DateTime
  completesAt DateTime

  status String @default("queued") // queued | done | cancelled

  @@index([userId])
  @@index([cityId])
  @@index([status, completesAt])
}

/// Pazar: asker (veya ileride kaynak) satışı; opensAt öncesi alım kapalı
model MarketListing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sellerId String
  seller   User   @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  cityId String
  city   City   @relation("ListingCity", fields: [cityId], references: [id], onDelete: Cascade)

  kind     String @default("soldiers")
  quantity Int

  priceWood Int @default(0)
  priceIron Int @default(0)
  priceFood Int @default(0)

  /// Geri sayım bittiğinde alım açılır
  opensAt DateTime

  status String @default("listed")

  buyerId String?
  buyer   User?   @relation("MarketBuyer", fields: [buyerId], references: [id])

  buyerCityId String?
  buyerCity   City?   @relation("BuyerCity", fields: [buyerCityId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@index([opensAt])
}

/// Basit oyun içi forum (MyBB yerine hafif MVP)
model ForumTopic {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts     ForumPost[]

  @@index([createdAt])
}

model ForumPost {
  id        String     @id @default(cuid())
  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String     @db.VarChar(8000)
  createdAt DateTime   @default(now())

  @@index([topicId, createdAt])
}

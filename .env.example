# Kopyala: cp .env.example .env  (Windows: copy .env.example .env)
#
# Neon: Connection details içinden iki URL kullanın:
# - "Pooled" / pooler → DATABASE_URL (uygulama)
# - "Direct" veya host’ta -pooler olmayan → DIRECT_URL (Prisma migrate)
# Yerel Postgres: DATABASE_URL ve DIRECT_URL aynı olabilir.
#
# Güvenlik: .env asla commitlenmez. Şifre sızdıysa Neon Console → branch → bağlantıyı yenile / şifreyi sıfırla.

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=120"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=120"

# Geliştirme + Vercel zorunlu: uzun rastgele dize
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Vercel’de tırnak koymayın; Production (ve gerekirse Preview) için ekleyin; kaydettikten sonra Redeploy.
AUTH_SECRET="yerelde-urettigin-deger"

# İsteğe bağlı: Vercel’de AUTH_SECRET ile aynı değer (eski dokümantasyon adı)
# NEXTAUTH_SECRET="aynı-deger"

# Vercel / üretim: tam kök adres (çoğu kurulumda trustHost ile şart değil)
# AUTH_URL="https://your-app.vercel.app"

ADMIN_PASSWORD="yalnizca-gelistirme"
